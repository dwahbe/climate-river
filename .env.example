# Database
# Primary database connection string (one of these is required)
DATABASE_URL=postgresql://user:password@host:port/database

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API Security
# Token to protect cron and admin endpoints (/api/cron/*, /api/ingest, /api/rescore, /api/rewrite).
# Used for manual/admin triggers via `Authorization: Bearer <token>` or `?token=...`.
ADMIN_TOKEN=your-secure-random-token

# Vercel Cron authentication (recommended). When set, Vercel automatically sends
# `Authorization: Bearer <CRON_SECRET>` on scheduled cron invocations, and the
# app stops trusting the spoofable `x-vercel-cron` header on its own. Leave unset
# to fall back to header-based auth (less secure). Generate with `openssl rand -hex 32`.
CRON_SECRET=your-secure-random-cron-secret

# Schema maintenance (optional)
# SEARCH_VECTOR_BACKFILL_BATCH_SIZE=250  # Batch size for schema search_vector backfill
# SEARCH_VECTOR_BACKFILL_ALL=0           # Set to 1 to rebuild all article search vectors in batches

# OpenAI (required for headline rewriting, categorization, and web discovery)
OPENAI_API_KEY=sk-your-openai-api-key

# Vercel AI Gateway (optional, for unified provider routing + observability)
# Local dev: required. Production on Vercel: optional — OIDC is auto-injected
# via VERCEL_OIDC_TOKEN, so the AI SDK falls back to that if this is unset.
AI_GATEWAY_API_KEY=vck-your-ai-gateway-key

# Google News Discovery (optional, for scripts/discover.ts)
# DISCOVER_HL=en-US          # Language code (default: en-US)
# DISCOVER_GL=US             # Country code (default: US)
# DISCOVER_CEID=US:en        # Combined country/language code (default: US:en)
# DISCOVER_QUERIES=climate change,global warming  # Comma-separated search queries

# Web Discovery (optional, for scripts/discover-web.ts)
# WEB_SEARCH_ENABLED=1                    # Set to 0 to disable (default: enabled)
# WEB_SEARCH_MODEL=gpt-4.1-mini           # Model for web search analysis (default: gpt-4.1-mini)
# GOOGLE_SUGGESTION_MODEL=gpt-4o-mini     # Model for query suggestions (default: gpt-4o-mini)
# WEB_SEARCH_CONTEXT_SIZE=medium          # low/medium/high (default: medium)
# WEB_SEARCH_FORCE_TOOL=1                 # Set to 0 to let the model skip the web-search tool (lowers cost)
# WEB_SEARCH_MAX_CALLS_PER_RUN=25         # Hard ceiling on paid OpenAI web-search calls per run (0 = unlimited)
# WEB_SEARCH_ALLOWED_DOMAINS=example.com  # Comma-separated list of allowed domains
# WEB_SEARCH_DEBUG=0                      # Set to 1 to enable debug logging
# OPENAI_WEB_SEARCH_TOOL_CALL_COST_USD=0.01
# TAVILY_API_KEY=tvly-your-tavily-api-key
# TAVILY_SEARCH_DEPTH=basic               # basic/advanced (default: basic)
# TAVILY_COST_PER_SEARCH_USD=0.008        # Override if your Tavily plan has different credit pricing

# Node Environment
NODE_ENV=development
